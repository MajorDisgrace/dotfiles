// -*- mode: jsonc -*-
{
  "height": 30,
  "layer": "top",
  "position": "top",
  "spacing": 5,

  "include": ["~/.config/waybar/modules.json"],

  "modules-left": [
    "niri/workspaces",
    "niri/window",
  ],
  "modules-center": [
    "clock",
  ],
  "modules-right": [
    "niri/language",
    "battery",
    "tray",
  ],
}
